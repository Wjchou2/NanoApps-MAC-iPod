def pick_target(apps=True, harnesses=True):
    """List the requested target kinds and let the user choose by number or name.
    apps/ are surface apps (installed to the home screen via the pack); harnesses/
    are fixed-VA .bin probes that are SCSI-exec'd once."""
    app_list, harn = [], []
    if apps:
        app_list = [d.name for d in sorted((ROOT / "apps").iterdir())
                    if (d / "Makefile").is_file() and d.name not in NONAPPS]
    if harnesses:
        harn = [d.name for d in sorted((ROOT / "harnesses").iterdir())
                if (d / "Makefile").is_file()]
    names = app_list + harn
    if app_list:
        print("\n  apps:")
        for i, a in enumerate(app_list, 1):
            print(f"    {i:>2}. {a}")
    if harn:
        print("\n  harnesses (one-shot exec):" if not app_list else "  harnesses (one-shot exec):")
        for i, h in enumerate(harn, len(app_list) + 1):
            print(f"    {i:>2}. {h}")
    raw = input("\n  number or name: ").strip()
    if raw.isdigit() and 1 <= int(raw) <= len(names):
        return names[int(raw) - 1]
    return raw


def _new_ns():
    """Prompt for the bits `start new` needs (name + surface kind)."""
    name = input("\n  new app name (lowercase): ").strip()
    print("  kind:  1) LVGL widgets   2) OpenGL   3) Paint-like (raw framebuffer)")
    kind = {"1": "lvgl", "2": "gl", "3": "raw"}.get(input("  choose [1/2/3]: ").strip(), "lvgl")
    return argparse.Namespace(name=name, kind=kind, frm=None, title=None)


def wizard(args, tr):
    ensure_build_deps()             # auto-check + install host deps at launch (silent if present)
    def ins(**kw):
        return argparse.Namespace(targets=kw.get("targets", []),
                                  demo_data=kw.get("demo_data", False),
                                  demo_data_force=kw.get("demo_data_force", False),
                                  resident_only=kw.get("resident_only", False))
    actions = [
        ("Install all apps",         lambda: cmd_install(ins(), tr)),
        ("Install all apps with demo data", lambda: cmd_install(ins(demo_data=True), tr)),
        ("Install all apps + FORCE-recopy demo data (overwrite on-device edits)",
                                     lambda: cmd_install(ins(demo_data=True, demo_data_force=True), tr)),
        ("Install one app",          lambda: cmd_install(ins(targets=[pick_target(harnesses=False)]), tr)),
        ("Install resident only (makes homebrew apps show up after restart)",
                                     lambda: cmd_install(ins(resident_only=True), tr)),
        ("Run a test harness once",  lambda: cmd_run(argparse.Namespace(target=pick_target(apps=False)), tr)),
        ("Pull screenshots and screen recordings", lambda: cmd_pull(argparse.Namespace(what="media", out=None), tr)),
        ("Pull benchmark CSVs",      lambda: cmd_pull(argparse.Namespace(what="bench", out=None), tr)),
        ("Build all (does not install onto device)", lambda: cmd_build(argparse.Namespace(targets=[]))),
        ("Create a new app",         lambda: cmd_new(_new_ns())),
        ("Install dependencies",     lambda: cmd_bootstrap(argparse.Namespace(check=False), tr)),
        ("Change iPod location (setup)", lambda: cmd_setup(argparse.Namespace())),
        ("Repair iPod disk (fsck)",  lambda: cmd_fsck(argparse.Namespace(), tr)),
        ("Peek DRAM",                lambda: cmd_peek(argparse.Namespace(addr=input("  addr (0x..): ").strip(), n="0x100"), tr)),
        ("Dump trace",               lambda: cmd_trace(argparse.Namespace(n=48), tr)),
        ("Eject iPod (return to Home Screen)", lambda: cmd_eject(argparse.Namespace(), tr)),
        ("Remount iPod disk (Connected mode)", lambda: cmd_remount(argparse.Namespace(), tr)),
    ]
    print(f"start — transport: {tr.desc}\n")
    for i, (label, _) in enumerate(actions, 1):
        print(f"  {i}. {label}")
    print("  q. quit")
    choice = input("\nchoose: ").strip().lower()
    if choice == "q" or not choice:
        return
    try:
        actions[int(choice) - 1][1]()
    except (ValueError, IndexError):
        print("invalid choice")


# -------------------------------------------------------------------- main ----
def main():
    p = argparse.ArgumentParser(prog="start", description="iPod build/deploy/probe driver")
    p.add_argument("--remote", "--pi", dest="remote", default=None,
                   help="SSH host (user@host) of the iPod's Linux computer; forces the SSH transport")
    p.add_argument("--local", action="store_true",
                   help="force local transport (the iPod is attached to THIS computer)")
    sub = p.add_subparsers(dest="cmd")

    # install (alias: deploy). --demo-data / --demo-data-force (aliases --data*).
    for name in ("install", "deploy"):
        sp = sub.add_parser(name)
        sp.add_argument("targets", nargs="*")
        sp.add_argument("--demo-data", "--data", dest="demo_data", action="store_true",
                        help="also copy data/<Name>/ -> /Apps/Data, skipping folders already on device")
        sp.add_argument("--demo-data-force", "--data-force", dest="demo_data_force", action="store_true",
                        help="copy data/ -> /Apps/Data, OVERWRITING folders already on device")
        sp.add_argument("--resident-only", action="store_true",
                        help="skip the app compile; rebuild + re-exec just the resident (repack/install reuse built blobs)")
    for name in ("deps", "bootstrap"):          # bootstrap == alias
        sp = sub.add_parser(name)
        sp.add_argument("--check", action="store_true", help="report missing deps but don't install")
    sub.add_parser("setup")
    sp = sub.add_parser("new")
    sp.add_argument("name", help="new app folder/executable name (lowercase)")
    sp.add_argument("--kind", choices=["lvgl", "gl", "raw"], default="lvgl",
                    help="surface kind: lvgl widgets (default), gl (OpenGL), raw (Paint-like framebuffer)")
    sp.add_argument("--from", dest="frm", metavar="APP",
                    help="clone a specific existing app instead of the kind's default template")
    sp.add_argument("--title", help="home-screen display name (default: from the name)")
    sp = sub.add_parser("run");    sp.add_argument("target")
    sp = sub.add_parser("build");  sp.add_argument("targets", nargs="*")
    sp = sub.add_parser("peek");   sp.add_argument("addr"); sp.add_argument("n", nargs="?", default="0x200")
    sp = sub.add_parser("trace");  sp.add_argument("n", nargs="?", type=int, default=48)
    sub.add_parser("eject")
    sub.add_parser("remount")
    sub.add_parser("fsck")
    sp = sub.add_parser("pull")
    sp.add_argument("what", nargs="?", choices=["media", "bench"], default="media",
                    help="media = screenshots + recordings (converted + encoded, then cleared); bench = benchmark CSVs")
    sp.add_argument("--out", help="output dir (media default: ~/Desktop/ipod_media_<ts>)")
    # recordings are encoded to video as part of a media pull: GIF + H.264 MP4 by
    # default; these add/extend the set.
    sp.add_argument("--prores",   action="store_true", help="also encode an Apple ProRes 4444 .mov")
    sp.add_argument("--lossless", action="store_true",
                    help="also encode a bit-exact QuickTime Animation (qtrle) .mov")
    sp.add_argument("--gif",      action="store_true", help="encode a GIF (default unless other formats are chosen)")
    sp.add_argument("--mp4",      action="store_true", help="encode an H.264 MP4 (default unless other formats are chosen)")
    sp.add_argument("--fps", type=int, default=30, help="recording frame rate (default 30)")
    sp.add_argument("--force", action="store_true", help="re-encode videos even if the output exists")
    sub.add_parser("wizard")

    args = p.parse_args()

    # these don't touch the device, so don't make them prompt for the iPod's location
    if args.cmd == "build":
        cmd_build(args); return
    if args.cmd == "setup":
        cmd_setup(args); return
    if args.cmd == "new":
        cmd_new(args); return

    # deps doesn't strictly need a configured device (host checks always run; the
    # device-tools section uses the transport only if one's already set up).
    tr = detect_transport(args, need_device=args.cmd not in ("deps", "bootstrap"))

    if args.cmd in ("install", "deploy"):
        cmd_install(args, tr)
    elif args.cmd in ("deps", "bootstrap"):
        cmd_bootstrap(args, tr)
    elif args.cmd == "run":
        cmd_run(args, tr)
    elif args.cmd == "peek":
        cmd_peek(args, tr)
    elif args.cmd == "trace":
        cmd_trace(args, tr)
    elif args.cmd == "eject":
        cmd_eject(args, tr)
    elif args.cmd == "remount":
        cmd_remount(args, tr)
    elif args.cmd == "fsck":
        cmd_fsck(args, tr)
    elif args.cmd == "pull":
        cmd_pull(args, tr)
    else:                                   # no subcommand -> interactive wizard
        wizard(args, tr)


if __name__ == "__main__":
    main()
