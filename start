def cmd_peek(args, tr):
    n = int(args.n, 0) if isinstance(args.n, str) else args.n
    data = tr.peek(int(args.addr, 0), n)
    for off in range(0, len(data), 16):
        row = data[off:off + 16]
        hexs = " ".join(f"{b:02x}" for b in row)
        asci = "".join(chr(b) if 32 <= b < 127 else "." for b in row)
        print(f"{int(args.addr,0)+off:08x}  {hexs:<48}  {asci}")


def cmd_trace(args, tr):
    data = tr.peek(TRACE_RING, 9 * 0x200)
    if len(data) < 16:
        sys.exit(f"peek returned no data — check the iPod is attached ({tr.desc})")
    magic, idx, count, _ = struct.unpack_from("<IIII", data, 0)
    if magic != TRACE_MAGIC:
        sys.exit("trace ring magic is %08x, not 'RTBH' — the resident hasn't logged yet "
                 "(or DRAM was cleared by a cold boot)" % magic)
    cap = (len(data) - 16) // 16          # ring slot count
    n = min(count, cap)
    tail = min(args.n, n)
    print(f"HBTR idx={idx} count={count}  (last {tail} of {n}, oldest first)")
    # circular ring: the newest entry is slot (idx-1); walk back `tail` then print
    # oldest-first so the LAST printed line is the most recent.
    slots = [(idx - 1 - k) % cap for k in range(tail)][::-1]
    for s in slots:
        o = 16 + s * 16
        tag = data[o:o + 8].rstrip(b" \x00").decode("ascii", "replace")
        v1, v2 = struct.unpack_from("<II", data, o + 8)
        print(f"{tag:<8} 0x{v1:08x} 0x{v2:08x}")


def cmd_pull(args, tr):
    """Pull files off the iPod's data disk (over whichever transport). `media` grabs
    screenshots + recordings, converts them, and clears them from the device;
    `bench` grabs the benchmark CSVs into bench_results/. Conversion is done here
    with Pillow + recsplit.py so it works on Linux and macOS alike."""
    what = getattr(args, "what", "media") or "media"

    if what == "bench":
        out = ROOT / "bench_results"; out.mkdir(exist_ok=True)
        n = tr._mount_pull(["Apps/Data/Bench/bench_*.csv"])
        if n < 0:
            sys.exit("could not mount the iPod (disk mode?) — try replugging")
        if n == 0:
            print("no benchmark CSVs on the device"); return
        tr._fetch(str(out))
        csvs = sorted(out.glob("bench_*.csv"))
        print(f"==> pulled {len(csvs)} CSV(s) -> {out}")
        if csvs:
            latest = max(csvs, key=lambda p: p.stat().st_mtime)
            print(f"\n=== {latest.name} ===\n{latest.read_text()}")
        return

    # media
    import datetime
    stamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    out = Path(args.out).expanduser() if getattr(args, "out", None) \
        else Path.home() / f"Desktop/ipod_media_{stamp}"
    orig = out / "originals"; orig.mkdir(parents=True, exist_ok=True)

    globs = ["screenshot[0-9]*.bmp", "rec[0-9]*.rec"]
    n = tr._mount_pull(globs)
    if n < 0:
        sys.exit("could not mount the iPod (disk mode?) — try replugging")
    if n == 0:
        print("nothing to pull (no screenshots/recordings on the iPod)")
        for p in (orig, out):
            try: p.rmdir()
            except OSError: pass
        return
    tr._fetch(str(orig))

    try:
        from PIL import Image
    except ImportError:
        sys.exit("Pillow is required to convert media — run `start deps`")
    nshot = nrec = 0
    for b in sorted(orig.glob("*.bmp")):
        (out / "screenshots").mkdir(exist_ok=True)
        try:
            Image.open(b).save(out / "screenshots" / (b.stem + ".png")); nshot += 1
        except Exception:
            pass
    for r in sorted(orig.glob("*.rec")):
        (out / "recordings").mkdir(exist_ok=True)
        d = out / "recordings" / r.stem
        if subprocess.run([sys.executable, str(ROOT / "tools" / "recsplit.py"), str(r), str(d)],
                          capture_output=True).returncode == 0:
            frames = len(list(d.glob("*.png")))
            print(f"   {r.stem} -> {frames} frame(s)"); nrec += 1

    # only wipe the device once the originals are safely on this machine
    tr._clear_device(globs)
    print(f"==> done: {nshot} screenshot(s), {nrec} recording(s) -> {out}  (iPod cleared)")

    # encode the recordings to video. Default = GIF + H.264 MP4; --prores / --lossless
    # add an Apple ProRes 4444 / a bit-exact qtrle .mov. ffmpeg is fetched on demand.
    recdirs = [d for d in sorted((out / "recordings").glob("rec*"))
               if d.is_dir() and next(d.glob("frame*.png"), None)] if nrec else []
    if recdirs:
        fmts = [f for f in ("gif", "mp4", "prores", "lossless") if getattr(args, f, False)]
        if not fmts:
            fmts = ["gif", "mp4"]
        if _ensure_ffmpeg():
            _encode_recordings(recdirs, out / "videos", fmts,
                               fps=getattr(args, "fps", 30), force=getattr(args, "force", False))
        else:
            print("   (frames kept; re-run with ffmpeg installed to encode video)")

    if platform.system() == "Darwin":
        subprocess.run(["open", str(out)], check=False)


# ----------------------------------------------------------- video encoding ---
def _ensure_ffmpeg():
    """ffmpeg is only needed to encode videos, so check for it lazily (here, the
    first time an encode runs) rather than in the general setup. If it's missing,
    offer to install it; if the user declines (or there's no way to), skip
    encoding and return False."""
    if _have("ffmpeg"):
        return True
    print("\nffmpeg is needed to encode videos, but it isn't installed.")
    if platform.system() == "Darwin":
        cmd, runner = "brew install ffmpeg", lambda: _run(["brew", "install", "ffmpeg"]).returncode == 0
    else:
        cmd = _linux_pkg_cmd("ffmpeg")
        runner = (lambda: _linux_install("ffmpeg")) if cmd else None
    if runner is None:
        print("  no known way to auto-install ffmpeg here — install it manually, then re-run.")
        return False
    if not _confirm(f"  install it now?  ({cmd})"):
        print("  skipping video encoding (ffmpeg not installed).")
        return False
    runner()
    if not _have("ffmpeg"):
        print("  ffmpeg still isn't on PATH — skipping video encoding.")
        return False
    return True


def _frame_key(p):
    """Numeric sort key so frame9999 < frame10000 (the recorder switches from 4- to
    5-digit names past 9999, which would otherwise mis-order a plain glob)."""
    return [int(t) if t.isdigit() else t for t in re.split(r"(\d+)", p.name)]


# codec recipes: ext + ffmpeg output args. 240x432 is even, so yuv420p is fine for H.264.
_VID_FMTS = {
    "gif":      ("gif",
                 ["-filter_complex", "[0:v] split [a][b];[a] palettegen [p];[b][p] paletteuse"]),
    "mp4":      ("mp4",
                 ["-c:v", "libx264", "-pix_fmt", "yuv420p", "-crf", "18",
                  "-preset", "slow", "-movflags", "+faststart"]),
    "prores":   ("prores.mov",
                 ["-c:v", "prores_ks", "-profile:v", "4444", "-pix_fmt", "yuv444p10le", "-vendor", "apl0"]),
    "lossless": ("lossless.mov",
                 ["-c:v", "qtrle", "-pix_fmt", "rgb24"]),
}


def _encode_recordings(recdirs, outdir, fmts, fps=30, force=False):
    """Encode each recNNNN frame folder in `recdirs` into the requested video
    formats under `outdir`. Caller has already ensured ffmpeg is available."""
    outdir.mkdir(parents=True, exist_ok=True)
    print(f"==> encoding {len(recdirs)} recording(s) -> {', '.join(fmts)} @ {fps}fps")
    made = skipped = 0
    for rd in recdirs:
        frames = sorted(rd.glob("frame*.png"), key=_frame_key)
        if not frames:
            continue
        # name <session>_<recNNNN> when the recordings/ layout is present, else recNNNN
        session = rd.parent.parent.name if rd.parent.name == "recordings" else ""
        stem = f"{session}_{rd.name}" if session else rd.name

        todo = [f for f in fmts
                if force or not (outdir / f"{stem}.{_VID_FMTS[f][0]}").exists()]
        for f in fmts:
            if f not in todo:
                print(f"   skip   {stem}.{_VID_FMTS[f][0]}  (exists)"); skipped += 1
        if not todo:
            continue

        # symlink the frames into a temp dir with uniform sequential numbering, so
        # ffmpeg reads them in true numeric order regardless of 4-/5-digit padding
        tmp = Path(tempfile.mkdtemp(prefix="nanovid_"))
        try:
            for i, fr in enumerate(frames):
                os.symlink(fr.resolve(), tmp / f"{i:06d}.png")
            for f in todo:
                ext, codec = _VID_FMTS[f]
                out = outdir / f"{stem}.{ext}"
                print(f"   encode {out.name}  ({len(frames)} frames)")
                rc = subprocess.run(
                    ["ffmpeg", "-y", "-nostdin", "-loglevel", "error", "-stats",
                     "-framerate", str(fps), "-start_number", "0", "-i", str(tmp / "%06d.png")]
                    + codec + ["-r", str(fps), str(out)]).returncode
                made += 1 if rc == 0 else 0
                if rc != 0:
                    print(f"   ! ffmpeg failed on {out.name}")
        finally:
            shutil.rmtree(tmp, ignore_errors=True)
    print(f"==> {made} video(s) encoded, {skipped} skipped -> {outdir}")


