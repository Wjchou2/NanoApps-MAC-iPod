def cmd_fsck(args, tr):
    """Repair the detected FAT or HFS+ data filesystem, then verify an RW mount."""
    dev = tr.dev(); part, fstype = tr.data_volume()
    ensure_device_deps(tr, FSCK_TOOLS[fstype])
    mnt = os.environ.get("IPOD_MOUNT", "/mnt/nanoapps-ipod")
    label = "HFS+" if fstype == "hfsplus" else "FAT"
    checker = (f"sudo fsck.vfat -a -w -v {part}"
               if fstype == "vfat" else f"sudo fsck.hfsplus -f -y {part}")
    print(f"==> repairing {part} ({label}) on the iPod's computer")
    script = f"""sudo sg_start {dev} --loej 2>/dev/null || true
for i in $(seq 1 40); do test -e {part} && break; sleep 1; done
test -e {part} || {{ echo 'device never appeared in Connected mode' >&2; exit 1; }}
udisksctl unmount -b {part} 2>/dev/null || sudo umount {part} 2>/dev/null || true
command -v {'fsck.hfsplus' if fstype == 'hfsplus' else 'fsck.vfat'} >/dev/null 2>&1 || {{ echo 'filesystem repair tool is missing' >&2; exit 1; }}
{checker} 2>&1 | tail -20 || true
echo '--- verifying read-write mount ---'
""" + _mount_prep(dev, part, fstype, mnt) + f"""sudo umount {mnt}
echo 'OK: the iPod {label} filesystem is healthy and writable'
"""
    rc = tr.sh(script, check=False).returncode
    tr.eject()              # back to the home screen
    if rc != 0:
        sys.exit(1)


def cmd_remount(args, tr):
    """Put the iPod into Connected mode and mount its detected data partition
    read-write on the iPod's computer (the inverse of eject)."""
    dev = tr.dev(); part, fstype = tr.data_volume()
    if fstype == "vfat":
        ensure_device_deps(tr, FSCK_TOOLS[fstype])
    mnt = os.environ.get("IPOD_MOUNT", "/mnt/nanoapps-ipod")
    print(f"==> mounting {part} ({'HFS+' if fstype == 'hfsplus' else 'FAT'}) read-write at {mnt}")
    tr.sh(_mount_prep(dev, part, fstype, mnt) + f"echo 'mounted read-write at {mnt}'")


